# Quest of the Roasted Bean – konfigurasjon for selvhosting med Docker.
# Kopier denne fila til «.env» og juster verdiene:  cp .env.example .env

# Porten appen skal være tilgjengelig på
PORT=3000

# Offentlig base-URL for marketing-domenet. Brukes til SEO: canonical-lenker,
# hreflang (no/en), sitemap.xml, robots.txt og delingsbilder (Open Graph).
# SETT DENNE i produksjon, ellers peker lenkene mot localhost.
# NEXT_PUBLIC_SITE_URL=https://dittdomene.no

# Første admin-bruker (opprettes automatisk ved oppstart)
ADMIN_NICKNAME=GameMaster
ADMIN_PIN=1234

# Hostet drift: sett ADMIN_EMAIL for å logge inn som admin med e-post magic-link
# (tryggere enn delt PIN over internett). Da kan ADMIN_PIN stå tom.
# ADMIN_EMAIL=admin@kunde.no

# Magic-link e-post sendes via Resend. Uten nøkkel logges lenken kun til konsollen.
# RESEND_API_KEY=re_xxx
# MAIL_FROM="Quest of the Roasted Bean <no-reply@dittdomene.no>"

# Valgfritt: support-e-post. Settes denne, vises en «Hjelp»-lenke i menyen for
# innloggede brukere (mailto med forhåndsutfylt emne). La stå tom for å skjule den.
# SUPPORT_EMAIL=support@dittdomene.no

# Valgfritt: fast base-URL for NFC-brikke-lenker (/t/<token>).
# Sett til adressen mobilene faktisk når serveren på (maskinens nettverks-/
# Tailscale-adresse), så «Kopier lenke» blir riktig uansett hvor admin åpnes.
# La stå tom for å bruke adressen i nettleseren.
# NEXT_PUBLIC_TAG_BASE_URL=http://192.0.2.3:3000

# Passord for den innebygde databasen (kan stå som det er for lokal kjøring)
POSTGRES_PASSWORD=quest-of-the-roasted-bean

# Valgfritt: full URL til en EKSTERN database i stedet for den innebygde.
# La denne stå tom for å bruke databasen som følger med (anbefalt).
# EXTERNAL_DATABASE_URL=postgresql://bruker:passord@vert:5432/quest-of-the-roasted-bean
