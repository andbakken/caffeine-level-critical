# ─────────────────────────────────────────────────────────────────────────────
# Hostet drift (control plane) – konfigurasjon.
# Kopier til infra/.env og fyll inn. infra/.env er git-ignorert (.env* i rot).
# Hold dette filen kryptert i repoet via sops/age hvis du vil committe (se infra/README.md).
# ─────────────────────────────────────────────────────────────────────────────

# ── Hetzner (kun for provision.sh, kjøres lokalt) ────────────────────────────
HCLOUD_TOKEN=                       # API-token (read/write) fra Hetzner Cloud-prosjektet
SERVER_NAME=brewquest-1
SERVER_TYPE=cx33                    # 4 vCPU / 8 GB – ~25 tenants. Bump cx43/cx53 ved vekst.
LOCATION=hel1                      # Helsinki (EU/GDPR, lavest latens mot Norge)
IMAGE=debian-12
SSH_KEY_NAME=brewquest             # navnet hcloud lagrer SSH-nøkkelen under
SSH_PUBLIC_KEY_FILE=~/.ssh/brewquest.pub
ADMIN_SSH_IP=                      # din offentlige IP (CIDR, f.eks. 203.0.113.7/32) – låser SSH (22)

# ── Domene / TLS ─────────────────────────────────────────────────────────────
BASE_DOMAIN=questroasted.app       # tenants blir <sub>.questroasted.app
ACME_EMAIL=you@example.com         # Let's Encrypt-varsler (utløp m.m.)
OWNER_EMAIL=you@example.com        # admin-innlogging (magic-link) på marketing-instansen (apex)

# ── Delt Postgres (kjører på serveren, ikke eksponert ut) ───────────────────
POSTGRES_SUPER_USER=postgres
POSTGRES_SUPER_PASSWORD=           # sterkt tilfeldig – superbruker control-plane bruker til CREATE DATABASE/ROLE

# ── Control plane ────────────────────────────────────────────────────────────
# Egen registry-DB i den delte Postgres-instansen (egen database, ikke en tenant).
CONTROL_PLANE_DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/control_plane
# Image control-plane starter per kunde (bygg + push, eller bygg lokalt på serveren).
TENANT_IMAGE=brewquest-app:latest
# Docker-nett tenants kobles på (må matche infra/compose.infra.yml).
EDGE_NETWORK=bq_edge
DATA_NETWORK=bq_data

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                 # sk_test_... (bytt til sk_live_... ved go-live)
STRIPE_WEBHOOK_SECRET=             # whsec_... (fra `stripe listen` eller dashboard)
STRIPE_PRICE_STANDARD=             # price_... (249 kr / $20)
STRIPE_PRICE_TEAM=                 # price_... (499 kr / $45)
# Gratis-tier (≤10 brukere) krever ikke Stripe-pris – provisjoneres uten betaling.

# ── Transaksjons-e-post (Resend, gratis 3k/mnd – eller EU-alt. Scaleway TEM) ──
RESEND_API_KEY=
MAIL_FROM="Quest of the Roasted Bean <no-reply@questroasted.app>"

# ── Backup (restic → Hetzner Storage Box / S3-kompatibelt) ───────────────────
RESTIC_REPOSITORY=                 # f.eks. sftp:u123456@u123456.your-storagebox.de:/backups
RESTIC_PASSWORD=                   # sterkt tilfeldig – krypteringsnøkkel for backupen (IKKE mist denne)
