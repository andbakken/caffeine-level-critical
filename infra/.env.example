# ─────────────────────────────────────────────────────────────────────────────
# Hostet drift (control plane) – konfigurasjon.
# Kopier til infra/.env og fyll inn. infra/.env er git-ignorert (.env* i rot).
# Hold dette filen kryptert i repoet via sops/age hvis du vil committe (se infra/README.md).
# ─────────────────────────────────────────────────────────────────────────────

# ── Hetzner (kun for provision.sh, kjøres lokalt) ────────────────────────────
HCLOUD_TOKEN=                       # API-token (read/write) fra Hetzner Cloud-prosjektet
SERVER_NAME=caffeine-level-critical-1
SERVER_TYPE=cx33                    # 4 vCPU / 8 GB – ~25 tenants. Bump cx43/cx53 ved vekst.
LOCATION=hel1                      # Helsinki (EU/GDPR, lavest latens mot Norge)
IMAGE=debian-12
SSH_KEY_NAME=caffeine-level-critical             # navnet hcloud lagrer SSH-nøkkelen under
SSH_PUBLIC_KEY_FILE=~/.ssh/caffeine-level-critical.pub
ADMIN_SSH_IP=                      # din offentlige IP (CIDR, f.eks. 203.0.113.7/32) – låser SSH (22)

# ── Domene / TLS ─────────────────────────────────────────────────────────────
BASE_DOMAIN=questroasted.app       # tenants blir <sub>.questroasted.app
ACME_EMAIL=you@example.com         # Let's Encrypt-varsler (utløp m.m.)
OWNER_EMAIL=you@example.com        # admin-innlogging (magic-link) på marketing-instansen (apex)

# ── Delt Postgres (kjører på serveren, ikke eksponert ut) ───────────────────
POSTGRES_SUPER_USER=postgres
POSTGRES_SUPER_PASSWORD=           # sterkt tilfeldig – superbruker control-plane bruker til CREATE DATABASE/ROLE
MARKETING_DB_PASSWORD=             # sterkt tilfeldig – begrenset rolle for marketing-appen (eier kun «marketing»-DB, ikke superbruker)

# ── Control plane ────────────────────────────────────────────────────────────
# Egen registry-DB i den delte Postgres-instansen (egen database, ikke en tenant).
CONTROL_PLANE_DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/control_plane
# Image control-plane starter per kunde (bygg + push, eller bygg lokalt på serveren).
TENANT_IMAGE=caffeine-level-critical-app:latest
# Docker-nett tenants kobles på (må matche infra/compose.infra.yml).
EDGE_NETWORK=bq_edge
DATA_NETWORK=bq_data

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                 # sk_test_... (bytt til sk_live_... ved go-live)
STRIPE_WEBHOOK_SECRET=             # whsec_... (fra `stripe listen` eller dashboard)
STRIPE_PRICE_STANDARD=             # price_... (249 kr / $20). 14 dagers gratis prøveperiode settes i control-plane (TRIAL_DAYS).

# ── Transaksjons-e-post (Resend, gratis 3k/mnd – eller EU-alt. Scaleway TEM) ──
RESEND_API_KEY=
MAIL_FROM="Caffeine Level Critical <no-reply@questroasted.app>"

# ── Juridisk identitet (kun apex) ────────────────────────────────────────────
# Hvem som leverer den hostede tjenesten: vises i vilkår og personvernerklæring.
# Står bevisst her og ikke i koden – repoet er offentlig, og en selvhoster skal
# ikke få våre personopplysninger med i klonen. Er navn/adresse/e-post tomme,
# 404-er /vilkar og /personvern i stedet for å rendre halve setninger.
LEGAL_COMPANY_NAME=                  # f.eks. «Ola Nordmann» (ENK står på innehavers navn)
LEGAL_COMPANY_ORGNR=                 # tom til foretaket er registrert; utelates da fra tekstene
LEGAL_COMPANY_ADDRESS_NO=            # f.eks. «Gata 1, 0001 Oslo, Norge» – e-handelsloven § 8 krever geografisk adresse
LEGAL_COMPANY_ADDRESS_EN=            # samme adresse, engelsk landnavn: «Gata 1, 0001 Oslo, Norway»
LEGAL_CONTACT_EMAIL=                 # GDPR-kontaktpunkt; MÅ motta e-post – bounce = brudd

# ── Aggregert bruksstatistikk ────────────────────────────────────────────────
STATS_TOKEN=                         # tilfeldig hemmelighet; kreves for GET /internal/stats. Tom = ruten av.

# ── Monitorering ─────────────────────────────────────────────────────────────
UMAMI_DB_PASSWORD=                   # sterkt tilfeldig – begrenset rolle for Umami (web-analyse)
UMAMI_APP_SECRET=                    # sterkt tilfeldig – Umami signeringshemmelighet (endring logger ut alle)
# Netdata basic-auth: opprett infra/netdata.htpasswd på serveren (git-ignorert):
#   htpasswd -nbB <bruker> <passord> > infra/netdata.htpasswd   (eller: openssl passwd -apr1)
UMAMI_SRC=                           # f.eks. https://analytics.<domene>/script.js (tom = ingen sporing)
UMAMI_WEBSITE_ID=                    # website-ID fra Umami-UI

# ── Backup (restic) – VALGFRITT, ikke i drift ────────────────────────────────
# Backupen som FAKTISK kjører er Hetzner Cloud Backups (daglige server-snapshots,
# 7 på rullering), slått på i Hetzner-konsollen – ikke noe som styres herfra.
# restic er et supplement: gjenoppretting av ÉN tenant-database uten å rulle
# tilbake alle andre kunder, og kopi utenfor Hetzner-kontoen. Står disse tomme,
# kjøres ingen restic-backup – det er et bevisst valg til det finnes kunder.
RESTIC_REPOSITORY=                 # f.eks. sftp:u123456@u123456.your-storagebox.de:/backups
RESTIC_PASSWORD=                   # sterkt tilfeldig – krypteringsnøkkel for backupen (IKKE mist denne)
