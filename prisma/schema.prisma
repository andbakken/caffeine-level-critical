// Caffeine Level Critical data model
// Prisma 7 — new `prisma-client` generator + better-sqlite3 driver adapter (no Rust engine).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id        Int          @id @default(autoincrement())
  name      String
  slug      String       @unique
  color     String       @default("#7c5cff")
  parentId  Int?
  parent    Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DeptHierarchy")
  createdAt DateTime     @default(now())
  users     User[]

  @@index([parentId])
}

model User {
  id           Int               @id @default(autoincrement())
  nickname     String            @unique
  email        String?           @unique // admin-innlogging via e-post magic-link (hostet)
  pinHash      String? // valgfri: spillere logger inn med PIN, e-post-admin trenger den ikke
  departmentId Int
  department   Department        @relation(fields: [departmentId], references: [id])
  avatarPath   String?
  isActive     Boolean           @default(true)
  isAdmin      Boolean           @default(false)
  createdAt    DateTime          @default(now())
  consumptions Consumption[]
  sessions     Session[]
  loginTokens  LoginToken[]
  achievements UserAchievement[]
}

// Engangs magic-link-token for passordløs admin-innlogging. `id` er sha256(token);
// selve token-en ligger bare i e-postlenken, aldri i databasen. Kort levetid + engangsbruk.
model LoginToken {
  id        String    @id // sha256-hash av råtoken
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Drink {
  id           Int           @id @default(autoincrement())
  key          String        @unique // coffee | tea | cocoa ...
  displayName  String
  icon         String // emoji / sprite key
  color        String        @default("#caa472")
  basePoints   Int           @default(1)
  sortOrder    Int           @default(0)
  consumptions Consumption[]
  tags         StationTag[]
  achievements Achievement[]
}

model Station {
  id           Int           @id @default(autoincrement())
  name         String
  location     String?
  color        String        @default("#39d98a")
  createdAt    DateTime      @default(now())
  tags         StationTag[]
  consumptions Consumption[]
}

model StationTag {
  id           Int           @id @default(autoincrement())
  token        String        @unique
  label        String?
  stationId    Int
  station      Station       @relation(fields: [stationId], references: [id])
  drinkId      Int? // if set -> one-tap logging; else -> drink picker
  drink        Drink?        @relation(fields: [drinkId], references: [id])
  createdAt    DateTime      @default(now())
  consumptions Consumption[]
}

model Consumption {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  drinkId   Int
  drink     Drink       @relation(fields: [drinkId], references: [id])
  quantity  Int         @default(1)
  source    String      @default("web") // web | tag
  stationId Int?
  station   Station?    @relation(fields: [stationId], references: [id])
  tagId     Int?
  tag       StationTag? @relation(fields: [tagId], references: [id])
  createdAt DateTime    @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([drinkId])
}

model Achievement {
  id          Int               @id @default(autoincrement())
  key         String            @unique
  name        String
  description String
  icon        String
  // Regelstyrt utdeling — admin definerer kriteriet:
  //   total       -> totalt antall kopper >= threshold
  //   distinct    -> antall ulike drikketyper >= threshold
  //   drink       -> antall av en bestemt drikke (drinkId) >= threshold
  //   before_hour -> en kopp logget før kl. threshold
  //   after_hour  -> en kopp logget kl. threshold eller senere
  ruleType    String            @default("total")
  threshold   Int               @default(1)
  drinkId     Int? // kun for ruleType = "drink"
  drink       Drink?            @relation(fields: [drinkId], references: [id])
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  users       UserAchievement[]
}

model UserAchievement {
  id            Int         @id @default(autoincrement())
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  achievementId Int
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
}

// App-vid branding (singleton, alltid id=1). Logo + plakat-tekst som admin styrer
// selv, brukt på A5-«skann her»-arkene. Appen er én-instans, så én rad holder.
model OrgProfile {
  id            Int      @id @default(1)
  logoPath      String? // filnavn i UPLOAD_DIR, serveres via /api/uploads/[file]
  posterHeading String? // CTA-overskrift på plakaten (default om tom)
  posterBody    String? // promotekst på plakaten (default om tom)
  updatedAt     DateTime @updatedAt
}

model Session {
  id        String   @id // random opaque token stored in httpOnly cookie
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
